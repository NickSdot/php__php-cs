{
    "name": "nicksdot/php-internals-cs",
    "description": "Standalone PHP internals PHPT style tools.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.5",
        "nikic/php-parser": "^5.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "InternalsCS\\": "src/"
        },
        "classmap": [
            "src/Fixers/",
            "src/PhptFile.php",
            "src/TestStyleFixer.php",
            "src/TestStyleFixerBase.php",
            "src/TestStyleRunner.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "InternalsCS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
