{
    "name": "nicksdot/php-cs",
    "description": "PHP project code style tools.",
    "type": "project",
    "license": "MIT",
    "require": {
        "ext-ctype": "*",
        "php": ">=8.5",
        "nikic/php-parser": "^5.8"
    },
    "require-dev": {
        "chevere/var-dump": "^2.0.10",
        "phpunit/phpunit": "^12.5.31",
        "friendsofphp/php-cs-fixer": "^3.95.15",
        "nicksdot/phpstan-phpstorm-error-identifiers": "^0.1.1",
        "phpstan/phpstan": "^2.2.5",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-strict-rules": "^2.0.11",
        "shipmonk/composer-dependency-analyser": "^1.8.4",
        "rector/rector": "^2.5.7"
    },
    "autoload": {
        "psr-4": {
            "InternalsCS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "stan": "./vendor/bin/phpstan analyse",
        "deps": "./vendor/bin/composer-dependency-analyser",
        "fixer": "export PHP_CS_FIXER_IGNORE_ENV=1; ./vendor/bin/php-cs-fixer",
        "fixer-fresh": "files=($(git --no-pager diff --name-only --diff-filter=ACMR HEAD | grep -E '\\.php$')); [ ${#files[@]} -gt 0 ] && vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --path-mode=intersection -- \"${files[@]}\"",
        "rector": "./vendor/bin/rector",
        "quality": [
          "@rector",
          "@fixer-fresh",
          "@stan"
        ]
    }
}
